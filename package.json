{
	"name": "homepage",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"gen": "wrangler types"
	},
	"dependencies": {
		"@dimforge/rapier3d-compat": "^0.19.3",
		"@fontsource-variable/cascadia-code": "^5.2.2",
		"@fontsource-variable/montserrat": "^5.2.8",
		"@fontsource/pt-serif": "^5.2.8",
		"@iconify-svelte/lucide": "^1.0.32",
		"@monogrid/gainmap-js": "^3.4.0",
		"@threlte/core": "^8.5.9",
		"@threlte/extras": "^9.14.7",
		"@threlte/rapier": "^3.4.2",
		"@types/three": "^0.184.0",
		"three": "^0.184.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"ts-essentials": "^10.1.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"wrangler": "^4.83.0"
	},
	"packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
	"pnpm": {
